---
import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';

export interface Props {
  images?: string[];
  image1?: string;
  image2?: string;
  image3?: string;
  image4?: string;
  image5?: string;
  image6?: string;
}

const { images: rawImages, image1, image2, image3, image4, image5, image6 } = Astro.props;

// Support both: array prop (Astro direct) or individual props (TinaCMS)
const images = (rawImages && rawImages.length > 0
  ? rawImages
  : [image1, image2, image3, image4, image5, image6].filter(Boolean) as string[]
).map(img => {
  if (img.startsWith('/') && !img.startsWith('http')) {
    return (import.meta.env.BASE_URL + img).replace(/\/+/g, '/');
  }
  return img;
});
---

{
  images && images.length > 0 && (
    <div class="carousel-container relative w-full max-w-2xl mx-auto my-12 group select-none opacity-0 translate-y-4 transition-all duration-1000 ease-out not-prose" data-carousel>
      <div class="carousel-viewport relative overflow-hidden rounded-2xl carousel-glass-frame">
        <div class="carousel-track flex transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]">
          {images.map((img, index) => (
            <div class="carousel-item flex-none w-full" data-index={index}>
              <div class="relative w-full flex items-center justify-center p-0.5">
                <Image
                  src={img}
                  alt={`Carousel image ${index + 1}`}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="w-full h-auto block object-contain rounded-[0.875rem]"
                />
              </div>
            </div>
          ))}
        </div>

        {/* ── Glass nav arrows ── */}
        <div class="absolute inset-y-0 left-0 right-0 flex items-center justify-between px-3 pointer-events-none z-10">
          <button
            class="carousel-nav-btn pointer-events-auto"
            aria-label="Previous image"
            data-prev
          >
            <Icon name="tabler:chevron-left" class="w-4 h-4" />
          </button>
          <button
            class="carousel-nav-btn pointer-events-auto"
            aria-label="Next image"
            data-next
          >
            <Icon name="tabler:chevron-right" class="w-4 h-4" />
          </button>
        </div>

        {/* ── Counter badge ── */}
        <div class="carousel-counter-badge" data-counter>
          1 / {images.length}
        </div>
      </div>

      {/* ── Glass pill pagination ── */}
      <div class="carousel-pill">
        {images.map((_, index) => (
          <button
            class="carousel-dot"
            aria-label={`Go to slide ${index + 1}`}
            data-dot={index}
          />
        ))}
      </div>
    </div>
  )
}

<style>
  /* ── Glass frame around viewport ── */
  .carousel-glass-frame {
    background: rgba(61, 125, 193, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1.5px solid rgba(61, 125, 193, 0.25);
    box-shadow:
      0 0 0 3px rgba(61, 125, 193, 0.06),
      0 8px 32px rgba(61, 125, 193, 0.1);
    height: auto;
    transition: height 0.7s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.3s ease, border-color 0.3s ease;
  }

  :global(.dark) .carousel-glass-frame {
    background: rgba(15, 23, 42, 0.5);
    border-color: rgba(61, 125, 193, 0.3);
    box-shadow:
      0 0 0 3px rgba(61, 125, 193, 0.08),
      0 8px 32px rgba(0, 0, 0, 0.35);
  }

  .carousel-container:hover .carousel-glass-frame {
    border-color: rgba(61, 125, 193, 0.4);
    box-shadow:
      0 0 0 3px rgba(61, 125, 193, 0.1),
      0 16px 48px rgba(61, 125, 193, 0.15);
  }

  :global(.dark) .carousel-container:hover .carousel-glass-frame {
    border-color: rgba(81, 145, 213, 0.45);
    box-shadow:
      0 0 0 3px rgba(61, 125, 193, 0.12),
      0 16px 48px rgba(0, 0, 0, 0.5);
  }

  /* ── Nav buttons ── */
  .carousel-nav-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    border: 1px solid rgba(61, 125, 193, 0.35);
    background: rgba(61, 125, 193, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #ffffff;
    cursor: pointer;
    box-shadow: 0 2px 10px rgba(61, 125, 193, 0.2);
    opacity: 0.85;
    transition: opacity 0.25s ease, background 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .carousel-container:hover .carousel-nav-btn {
    opacity: 1;
  }

  .carousel-nav-btn:hover {
    background: rgba(61, 125, 193, 0.7);
    border-color: rgba(61, 125, 193, 0.6);
    transform: scale(1.08);
    box-shadow: 0 4px 18px rgba(61, 125, 193, 0.35);
  }

  .carousel-nav-btn:disabled {
    opacity: 0.25 !important;
    pointer-events: none;
  }

  :global(.dark) .carousel-nav-btn {
    background: rgba(61, 125, 193, 0.25);
    border-color: rgba(81, 145, 213, 0.35);
  }

  :global(.dark) .carousel-nav-btn:hover {
    background: rgba(81, 145, 213, 0.6);
    border-color: rgba(81, 145, 213, 0.6);
  }

  /* ── Counter badge ── */
  .carousel-counter-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #ffffff;
    background: rgba(61, 125, 193, 0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(61, 125, 193, 0.4);
    border-radius: 8px;
    padding: 4px 10px;
  }

  :global(.dark) .carousel-counter-badge {
    background: rgba(61, 125, 193, 0.45);
    border-color: rgba(81, 145, 213, 0.35);
  }

  /* ── Pill dots ── */
  .carousel-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 14px;
    padding: 6px 14px;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
    border-radius: 9999px;
    background: rgba(61, 125, 193, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(61, 125, 193, 0.18);
    box-shadow: 0 2px 8px rgba(61, 125, 193, 0.06);
  }

  :global(.dark) .carousel-pill {
    background: rgba(61, 125, 193, 0.1);
    border-color: rgba(61, 125, 193, 0.2);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    border: none;
    padding: 0;
    cursor: pointer;
    background: rgba(100, 116, 139, 0.35);
    transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
  }

  :global(.dark) .carousel-dot {
    background: rgba(148, 163, 184, 0.35);
  }

  .carousel-dot:hover {
    background: rgba(61, 125, 193, 0.5);
  }

  .carousel-dot.active {
    background: rgb(61 125 193);
    width: 20px;
  }

  :global(.dark) .carousel-dot.active {
    background: rgb(81 145 213);
  }

  /* ── Ready state ── */
  [data-carousel].is-ready {
    opacity: 1;
    transform: translateY(0);
  }

  .carousel-track {
    will-change: transform;
  }
</style>

<script>
  function setupCarousel(container: HTMLElement) {
    const viewport = container.querySelector('.carousel-viewport') as HTMLElement;
    const track = container.querySelector('.carousel-track') as HTMLElement;
    const items = container.querySelectorAll('.carousel-item');
    const prevBtn = container.querySelector('[data-prev]') as HTMLButtonElement;
    const nextBtn = container.querySelector('[data-next]') as HTMLButtonElement;
    const dots = container.querySelectorAll('[data-dot]');
    const counter = container.querySelector('[data-counter]');
    
    if (!viewport || !track || items.length === 0) return;

    let currentIndex = 0;
    const total = items.length;

    const updateHeight = () => {
      const activeItem = items[currentIndex] as HTMLElement;
      if (activeItem) {
        viewport.style.height = `${activeItem.offsetHeight}px`;
      }
    };

    // Auto-play logic
    let autoplayInterval: number | null = null;
    const AUTOPLAY_DELAY = 5000; // 5 seconds

    const startAutoplay = () => {
      stopAutoplay();
      autoplayInterval = window.setInterval(() => {
        const nextIndex = (currentIndex + 1) % total;
        update(nextIndex);
      }, AUTOPLAY_DELAY);
    };

    const stopAutoplay = () => {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
        autoplayInterval = null;
      }
    };

    const update = (index: number) => {
      currentIndex = (index + total) % total; // Support wrapping for autoplay
      
      track.style.transform = `translateX(-${currentIndex * 100}%)`;

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIndex);
      });

      if (counter) {
        counter.textContent = `${currentIndex + 1} / ${total}`;
      }

      if (prevBtn) prevBtn.disabled = false; // Disable disabled state for infinite feel in autoplay
      if (nextBtn) nextBtn.disabled = false;

      requestAnimationFrame(updateHeight);
    };

    prevBtn?.addEventListener('click', (e) => { e.preventDefault(); stopAutoplay(); update(currentIndex - 1); startAutoplay(); });
    nextBtn?.addEventListener('click', (e) => { e.preventDefault(); stopAutoplay(); update(currentIndex + 1); startAutoplay(); });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', (e) => { e.preventDefault(); stopAutoplay(); update(index); startAutoplay(); });
    });

    container.addEventListener('mouseenter', stopAutoplay);
    container.addEventListener('mouseleave', startAutoplay);

    window.addEventListener('resize', () => {
        updateHeight();
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
    });

    // Touch / swipe
    let startX = 0;
    container.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; stopAutoplay(); }, { passive: true });
    container.addEventListener('touchend', (e) => {
      const dist = startX - e.changedTouches[0].clientX;
      if (Math.abs(dist) > 50) update(currentIndex + (dist > 0 ? 1 : -1));
      startAutoplay();
    }, { passive: true });

    // Keyboard
    container.setAttribute('tabindex', '0');
    container.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { stopAutoplay(); update(currentIndex - 1); startAutoplay(); }
      if (e.key === 'ArrowRight') { stopAutoplay(); update(currentIndex + 1); startAutoplay(); }
    });

    container.classList.add('is-ready');
    
    const images = track.querySelectorAll('img');
    let loadedCount = 0;
    const handleLoad = () => {
      loadedCount++;
      if (loadedCount === images.length || images[currentIndex].complete) {
        update(currentIndex);
      }
    };

    images.forEach(img => {
      if (img.complete) handleLoad();
      else img.addEventListener('load', handleLoad);
    });

    update(0);
    startAutoplay();
    setTimeout(() => update(0), 500);
  }

  const init = () => {
    document.querySelectorAll('[data-carousel]').forEach((c) => setupCarousel(c as HTMLElement));
  };

  document.addEventListener('astro:page-load', init);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
