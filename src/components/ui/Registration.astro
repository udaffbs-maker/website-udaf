---
import Button from '~/components/ui/Button.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  link?: string;
  text?: string;
}

const { title = 'Event Registration', subtitle = 'Secure your spot for this event. Limited seats available!', link = '#', text = 'Register Now' } = Astro.props;
---

<div class="my-10 p-8 rounded-3xl bg-primary/5 dark:bg-primary/10 border border-primary/20 dark:border-primary/30 text-center max-w-2xl mx-auto shadow-sm transition-all hover:shadow-xl hover:shadow-primary/5 group not-prose">
  {title && <h3 class="text-2xl font-bold mb-4 dark:text-white group-hover:text-primary transition-colors">{title}</h3>}
  {subtitle && <p class="text-muted dark:text-slate-400 mb-8 max-w-md mx-auto" set:html={subtitle} />}
  <Button variant="primary" href={link} class="px-10 py-4 text-lg font-bold">
    {text}
  </Button>
</div>
