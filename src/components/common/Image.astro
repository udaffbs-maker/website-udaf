---
import type { HTMLAttributes } from 'astro/types';
import { findImage } from '~/utils/images';
import {
  getImagesOptimized,
  astroAssetsOptimizer,
  unpicOptimizer,
  isUnpicCompatible,
  type ImageProps,
} from '~/utils/images-optimization';
import { optimizeCloudinaryUrl, isCloudinaryUrl } from '~/utils/cloudinary';

type Props = ImageProps;
type ImageType = {
  src: string;
  attributes: HTMLAttributes<'img'>;
};

const props = Astro.props;

if (props.alt === undefined || props.alt === null) {
  throw new Error();
}

if (typeof props.width === 'string') {
  props.width = parseInt(props.width);
}

if (typeof props.height === 'string') {
  props.height = parseInt(props.height);
}

if (!props.loading) {
  props.loading = 'lazy';
}

if (!props.decoding) {
  props.decoding = 'async';
}

const _image = await findImage(props.src);

let image: ImageType | undefined = undefined;

if (_image) {
  if (
    typeof _image === 'string' &&
    _image.startsWith('/') &&
    !_image.startsWith('http://') &&
    !_image.startsWith('https://')
  ) {
    // Local public images (e.g. /images/...): pass through as-is
    image = {
      src: _image,
      attributes: props as HTMLAttributes<'img'>,
    };
  } else {
    const layout = props.layout || (props.width || props.height ? 'constrained' : 'fullWidth');
    const optimizedProps = { ...props, layout };

    if (
      typeof _image === 'string' &&
      (_image.startsWith('http://') || _image.startsWith('https://')) &&
      isCloudinaryUrl(_image)
    ) {
      // Cloudinary images: inject f_auto,q_auto and pass through as-is (CDN handles optimization)
      const optimizedUrl = optimizeCloudinaryUrl(_image);
      image = await getImagesOptimized(optimizedUrl, optimizedProps, unpicOptimizer);
    } else if (
      typeof _image === 'string' &&
      (_image.startsWith('http://') || _image.startsWith('https://')) &&
      isUnpicCompatible(_image)
    ) {
      image = await getImagesOptimized(_image, optimizedProps, unpicOptimizer);
    } else {
      image = await getImagesOptimized(_image, optimizedProps, astroAssetsOptimizer);
    }
  }
}
---

{
  !image ? (
    <Fragment />
  ) : (
    <img src={image.src} crossorigin="anonymous" referrerpolicy="no-referrer" {...image.attributes} />
  )
}
