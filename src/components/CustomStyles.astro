---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(61 125 193); /* UDAF Blue #3D7DC1 */
    --aw-color-secondary: rgb(43 93 148); /* Darker UDAF Blue */
    --aw-color-accent: rgb(21 53 91); /* Even darker blue */

    --aw-color-text-heading: rgb(15 23 42); /* slate-900 */
    --aw-color-text-default: rgb(51 65 85); /* slate-700 */
    --aw-color-text-muted: rgb(100 116 139); /* slate-500 */
    --aw-color-text-page: rgb(15 23 42); /* slate-900 */
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(15 23 42); /* slate-900 */

    ::selection {
      background-color: rgba(61, 125, 193, 0.2);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(81 145 213); /* Lighter UDAF Blue for dark mode */
    --aw-color-secondary: rgb(101 165 233); /* Even lighter blue */
    --aw-color-accent: rgb(141 185 243); /* Accent blue */

    --aw-color-text-heading: rgb(248 250 252); /* slate-50 */
    --aw-color-text-default: rgb(203 213 225); /* slate-300 */
    --aw-color-text-muted: rgb(148 163 184); /* slate-400 */
    --aw-color-text-page: rgb(248 250 252); /* slate-50 */
    --aw-color-bg-page: rgb(15 23 42); /* slate-900 */

    ::selection {
      background-color: rgba(81, 145, 213, 0.4);
      color: white;
    }
  }
</style>
