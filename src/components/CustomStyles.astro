---
import '@fontsource-variable/montserrat';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Montserrat Variable';
    --aw-font-serif: 'Montserrat Variable';
    --aw-font-heading: 'Montserrat Variable';

    --aw-color-primary: rgb(29 78 216); /* blue-700 */
    --aw-color-secondary: rgb(30 58 138); /* blue-900 */
    --aw-color-accent: rgb(147 51 234); /* purple-600 */

    --aw-color-text-heading: rgb(15 23 42); /* slate-900 */
    --aw-color-text-default: rgb(51 65 85); /* slate-700 */
    --aw-color-text-muted: rgb(100 116 139); /* slate-500 */
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(15 23 42); /* slate-900 */

    ::selection {
      background-color: rgba(29, 78, 216, 0.2);
    }
  }

  .dark {
    --aw-font-sans: 'Montserrat Variable';
    --aw-font-serif: 'Montserrat Variable';
    --aw-font-heading: 'Montserrat Variable';

    --aw-color-primary: rgb(59 130 246); /* blue-500 */
    --aw-color-secondary: rgb(96 165 250); /* blue-400 */
    --aw-color-accent: rgb(168 85 247); /* purple-500 */

    --aw-color-text-heading: rgb(248 250 252); /* slate-50 */
    --aw-color-text-default: rgb(203 213 225); /* slate-300 */
    --aw-color-text-muted: rgb(148 163 184); /* slate-400 */
    --aw-color-bg-page: rgb(15 23 42); /* slate-900 */

    ::selection {
      background-color: rgba(59, 130, 246, 0.4);
      color: white;
    }
  }
</style>
