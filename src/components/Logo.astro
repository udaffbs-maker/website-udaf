---
import { SITE } from 'astrowind:config';
import logoImg from '~/assets/images/udaf-logo.png';
import Image from '~/components/common/Image.astro';
---

<span
  class="self-center ml-2 rtl:ml-0 rtl:mr-2 text-2xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white flex items-center gap-2"
>
  <Image src={logoImg} alt="UDAF Logo" width={40} height={40} class="rounded-full bg-white p-0.5 object-contain" />
  {SITE?.name}
</span>
