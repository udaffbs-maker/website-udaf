---
import fs from 'node:fs';
import yaml from 'js-yaml';
import Layout from '~/layouts/PageLayout.astro';
import TeamGrid from '~/components/widgets/TeamGrid.astro';

const data = yaml.load(fs.readFileSync('./src/data/committees/executive-committee-2025.yaml', 'utf8')) as any;
const { title, presidentialPanel, vicePresidents } = data;

const metadata = {
  title: title,
};
---

<Layout metadata={metadata}>
  <section class="relative py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-3 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade-down">Meet Our Team</p>
        <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl text-gray-900 dark:text-white mb-4 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade-up">
          Executive Committee
          <span class="block text-primary">2025</span>
        </h1>
        <div class="w-24 h-1 bg-gradient-to-r from-primary to-secondary mx-auto rounded-full intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade-up"></div>
      </div>
    </div>

    <TeamGrid presidentialPanel={presidentialPanel} vicePresidents={vicePresidents} />
  </section>
</Layout>
