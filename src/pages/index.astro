---
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';

import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const homeDataPath = path.join(process.cwd(), 'src/data/pages/home.yaml');
const data = yaml.load(fs.readFileSync(homeDataPath, 'utf8')) as any;
const { metadata, hero, stats, features, about, cta } = data;
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero actions={hero.actions} tagline="Welcome to UDAF" images={hero.images}>
    <Fragment slot="title">
      {hero.title1}
      <br />
      <span class="highlight">
        {hero.title2}
      </span>
    </Fragment>

    <Fragment slot="subtitle">
      <Fragment set:html={hero.subtitle} />
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats stats={stats} />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline={features.tagline}
    title={features.title}
    subtitle={features.subtitle}
    items={features.items}
  />

  <!-- Content Widget **************** -->

  <Content isReversed tagline={about.tagline} title={about.title} items={about.items} image={about.image}>
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{about.subtitle}</h3>
      <div class="text-muted dark:text-slate-400">
        {about.description}
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50/50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction actions={cta.actions}>
    <Fragment slot="title">
      <Fragment set:html={cta.title} />
    </Fragment>

    <Fragment slot="subtitle">
      {cta.subtitle}
    </Fragment>
  </CallToAction>
</Layout>

<style>
  .highlight {
    background-image: linear-gradient(to right, #3d7dc1, #1e40af);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  :global(.dark) .highlight {
    background-image: linear-gradient(to right, #93c5fd, #ffffff);
  }
</style>
