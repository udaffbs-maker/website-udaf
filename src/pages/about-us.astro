---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FacultyCarousel from '~/components/widgets/FacultyCarousel.astro';
import Layout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import yaml from 'js-yaml';
import fs from 'fs';
import path from 'path';
import type { FacultyMessage } from '~/components/widgets/FacultyCarousel.astro';
import type { Item } from '~/types';

interface AboutUsData {
  metadata: { title: string };
  hero: { tagline?: string; title?: string; subtitle?: string };
  journey: { title?: string; content?: string; image?: { src: string; alt: string } };
  purpose: { title?: string; subtitle?: string; items?: Item[] };
  objectives: { title?: string; subtitle?: string; items?: Item[] };
  facultyMessages: { title?: string; messages: FacultyMessage[] };
}

const aboutUsData = yaml.load(
  fs.readFileSync(path.resolve('./src/data/pages/about-us.yaml'), 'utf8')
) as AboutUsData;
const { metadata, hero, journey, purpose, objectives, facultyMessages } = aboutUsData;
---

<Layout metadata={metadata}>
  <!-- Journey Section (Shadcn-styled) -->
  <section class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 lg:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Text Side -->
      <div class="space-y-6 md:space-y-8 order-2 md:order-1">
        <div class="space-y-4">
          <div class="inline-flex items-center rounded-full border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-900/30 px-3 py-1 text-xs font-semibold text-primary transition-colors hover:bg-blue-100 dark:hover:bg-blue-900/50">
            About Us
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 dark:text-white font-heading">
            {journey.title}
          </h1>
          {hero.subtitle && (
            <p class="text-lg md:text-xl text-muted dark:text-slate-400 font-medium leading-relaxed">
              {hero.subtitle}
            </p>
          )}
        </div>
        
        <div class="prose prose-sm md:prose-base dark:prose-invert text-muted dark:text-slate-400 leading-relaxed text-justify max-w-none">
          {journey.content?.split('\n\n').map((paragraph) => (
            paragraph.trim() ? <p class="mb-4">{paragraph.trim()}</p> : null
          ))}
        </div>
      </div>
      
      <!-- Image Side -->
      <div class="order-1 md:order-2 relative aspect-square md:aspect-[4/5] rounded-2xl overflow-hidden border border-gray-200 dark:border-slate-800 shadow-xl shadow-black/5 dark:shadow-black/20">
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent z-10 rounded-2xl pointer-events-none"></div>
        {journey.image && (
          <Image
            src={journey.image.src}
            alt={journey.image.alt || 'Our Journey'}
            width={800}
            height={1000}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 hover:scale-105"
          />
        )}
      </div>
    </div>
  </section>

  <!-- Features3 Widget ************** -->
  <Features3
    title={purpose.title}
    subtitle={purpose.subtitle}
    columns={3}
    isBeforeContent={true}
    items={purpose.items}
  />

  <!-- Features2 Widget ************** -->
  <Features2
    title={objectives.title}
    subtitle={objectives.subtitle}
    columns={3}
    items={objectives.items}
  />

  <!-- Faculty Messages Carousel *** -->
  <FacultyCarousel
    title={facultyMessages.title}
    messages={facultyMessages.messages}
  />
</Layout>
