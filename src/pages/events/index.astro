---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Events - UDAF',
};

// Fetch all events from the content collection
const allEvents = await getCollection('event');

// Build slug for each event (same logic as [...slug].astro)
const events = allEvents
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA; // newest first
  })
  .map((event) => {
    let slug = event.data.slug || event.id;
    slug = slug.replace(/^\/+|\/+$/g, '');
    slug = slug.replace(/^events\/+/i, '');
    return {
      title: event.data.title,
      date: event.data.date,
      image: event.data.image || event.data.coverImage,
      slug,
      href: `/events/${slug}`,
    };
  });
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-6xl">
    <header class="text-center mb-16">
      <p class="text-sm font-bold tracking-wider text-primary uppercase mb-3">Our Events</p>
      <h1 class="font-bold font-heading text-4xl md:text-5xl mb-4 text-gray-900 dark:text-white tracking-tight">
        Exciting Activities at UDAF
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Join us in our various events designed to foster growth, networking, and fun.
      </p>
      <div class="w-20 h-1.5 bg-primary mx-auto rounded-full mt-6"></div>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {events.map((event) => (
        <a
          href={event.href}
          class="group relative flex flex-col overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
        >
          {event.image ? (
            <div class="aspect-video overflow-hidden">
              <img
                src={event.image}
                alt={event.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          ) : (
            <div class="aspect-video bg-gradient-to-br from-primary/20 to-primary/5 dark:from-primary/30 dark:to-primary/10 flex items-center justify-center">
              <Icon name="tabler:calendar-event" class="w-12 h-12 text-primary/60" />
            </div>
          )}
          <div class="flex flex-col flex-grow p-5">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors duration-200 mb-2">
              {event.title}
            </h2>
            {event.date && (
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-auto">
                {new Date(event.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            )}
          </div>
          <div class="absolute bottom-0 left-0 right-0 h-1 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </a>
      ))}
    </div>

    {events.length === 0 && (
      <div class="text-center py-20">
        <Icon name="tabler:calendar-off" class="w-16 h-16 text-gray-300 dark:text-gray-600 mx-auto mb-4" />
        <p class="text-gray-500 dark:text-gray-400 text-lg">No events found yet. Check back soon!</p>
      </div>
    )}
  </section>
</Layout>
